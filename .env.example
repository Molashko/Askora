APP_ENV=development
APP_SECRET_KEY=change-me-before-prod
AUTH_COOKIE_SECURE=
DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/analytics_hub
REDIS_URL=redis://redis:6379/0
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

LLM_PROVIDER=gemini
LLM_MODEL=
LLM_MAX_OUTPUT_TOKENS=1400
LOCAL_INTENT_MODEL_PATH=app/ai/model/local_intent_model.json
LOCAL_INTENT_MIN_SIMILARITY=0.24
LOCAL_INTENT_MIN_MARGIN=0.01

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

QUERY_TIMEOUT_MS=5000
MAX_RESULT_ROWS=500
MAX_SQL_COMPLEXITY=12
MAX_QUERY_COST=250000
QUERY_RATE_LIMIT_PER_WINDOW=30
QUERY_RATE_LIMIT_WINDOW_SECONDS=60
SEED_DEMO_DATA=true
DATASET_CSV_PATH=/app/data/train.csv
SCHEDULER_TIMEZONE=Europe/Kaliningrad
EMAIL_STUB_SENDER=reports@analytics.local
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
